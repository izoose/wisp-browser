<Window x:Class="Wisp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Wisp"
        Title="Wisp" Height="720" Width="1120"
        Icon="wisp.ico"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBrush}"
        FontFamily="{StaticResource UiFont}"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="ClearType">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title bar + tabs -->
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="Auto"/>  <!-- bookmarks bar -->
            <RowDefinition Height="*"/>     <!-- content -->
        </Grid.RowDefinitions>

        <!-- Title bar: tabs live here (drag the empty area to move the window) -->
        <Grid x:Name="TitleTabBar" Grid.Row="0" Background="{StaticResource ChromeBrush}" Height="40"
              SizeChanged="TabScroller_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- tab scroller (width-capped so tabs shrink) -->
                <ColumnDefinition Width="Auto"/>  <!-- + button, always visible -->
                <ColumnDefinition Width="*"/>     <!-- caption drag area -->
                <ColumnDefinition Width="Auto"/>  <!-- window controls -->
            </Grid.ColumnDefinitions>

            <!-- Tabs only; the + button and caption drag area sit to the right of this -->
            <ScrollViewer x:Name="TabScroller" Grid.Column="0" VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Hidden" VerticalAlignment="Bottom"
                          SizeChanged="TabScroller_SizeChanged">
                <ItemsControl x:Name="TabStrip" ItemsSource="{Binding Tabs}"
                              PreviewMouseLeftButtonDown="TabStrip_MouseDown"
                              PreviewMouseMove="TabStrip_MouseMove"
                              PreviewMouseLeftButtonUp="TabStrip_MouseUp">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TabRoot" Width="{Binding Width}" Margin="2,6,0,0" ClipToBounds="True"
                                    WindowChrome.IsHitTestVisibleInChrome="True" MouseDown="Tab_MouseDown"
                                    MouseEnter="Tab_HoverEnter" MouseLeave="Tab_HoverLeave"
                                    CornerRadius="8,8,0,0" Background="{StaticResource TabInactiveBrush}">
                                    <Border.ContextMenu>
                                        <ContextMenu Style="{StaticResource DarkContextMenu}">
                                            <ContextMenu.Resources>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource DarkMenuItem}"/>
                                                <Style TargetType="Separator" BasedOn="{StaticResource DarkSeparator}"/>
                                            </ContextMenu.Resources>
                                            <MenuItem Header="New tab" Click="Ctx_NewTab"/>
                                            <MenuItem Header="Duplicate tab" Click="Ctx_Duplicate"/>
                                            <MenuItem Header="Pin / Unpin tab" Click="Ctx_Pin"/>
                                            <MenuItem Header="Mute / Unmute tab" Click="Ctx_Mute"/>
                                            <Border Height="1" Background="{StaticResource EdgeBorderBrush}" Margin="8,5"/>
                                            <MenuItem Header="Close tab" Click="Ctx_Close"/>
                                            <MenuItem Header="Close other tabs" Click="Ctx_CloseOthers"/>
                                            <MenuItem Header="Close tabs to the right" Click="Ctx_CloseRight"/>
                                            <Border Height="1" Background="{StaticResource EdgeBorderBrush}" Margin="8,5"/>
                                            <MenuItem Header="Reopen closed tab" Click="Ctx_Reopen"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" ToolTip="{Binding Url}" Click="Tab_Click"
                                                Style="{StaticResource TabButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Favicon}" Width="16" Height="16"
                                                       Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Style.Triggers>
                                                                <Trigger Property="Source" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" FontSize="12" MaxWidth="118"
                                                           Foreground="{StaticResource TextBrush}"
                                                           Visibility="{Binding ShowTitle, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="AudioBtn" Grid.Column="1" Content="&#xE767;" Click="TabAudio_Click"
                                                ToolTip="Mute tab" Style="{StaticResource TabMiniStyle}"
                                                Visibility="{Binding ShowAudio, Converter={StaticResource BoolToVis}}"/>
                                        <Button x:Name="CloseBtn" Grid.Column="2" Content="&#xE711;" Click="TabClose_Click"
                                                ToolTip="Close tab (Ctrl+W)" Style="{StaticResource TabCloseStyle}"
                                                Visibility="{Binding ShowClose, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter TargetName="TabRoot" Property="Background"
                                                Value="{StaticResource TabActiveBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                        <Setter TargetName="AudioBtn" Property="Content" Value="&#xE74F;"/>
                                        <Setter TargetName="AudioBtn" Property="ToolTip" Value="Unmute tab"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- New-tab button: always visible, right after the tab strip -->
                <Button x:Name="NewTabBtn" Grid.Column="1" Content="&#xE710;" Click="NewTab_Click"
                        Style="{StaticResource ToolButtonStyle}" Margin="4,0,0,0" VerticalAlignment="Bottom"
                        WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="New tab (Ctrl+T)"/>

                <!-- Window controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinBtn" Content="&#xE921;" Click="Minimize_Click"
                            Style="{StaticResource CaptionButtonStyle}" ToolTip="Minimize"/>
                    <Button x:Name="MaxBtn" Content="&#xE922;" Click="MaxRestore_Click"
                            Style="{StaticResource CaptionButtonStyle}" ToolTip="Maximize"/>
                    <Button x:Name="CloseBtn" Content="&#xE8BB;" Click="Close_Click"
                            Style="{StaticResource CaptionCloseStyle}" ToolTip="Close"/>
                </StackPanel>
            </Grid>

        <!-- Toolbar -->
        <Border x:Name="ToolbarRow" Grid.Row="1" Background="{StaticResource ChromeBrush}" Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="BackBtn" Content="&#xE72B;" Click="Back_Click"
                            Style="{StaticResource ToolButtonStyle}" ToolTip="Back (Alt+Left)"/>
                    <Button x:Name="ForwardBtn" Content="&#xE72A;" Click="Forward_Click"
                            Style="{StaticResource ToolButtonStyle}" ToolTip="Forward (Alt+Right)"/>
                    <Button x:Name="ReloadBtn" Content="&#xE72C;" Click="Reload_Click"
                            Style="{StaticResource ToolButtonStyle}" ToolTip="Reload (Ctrl+R)"/>
                </StackPanel>

                <Border x:Name="AddressHost" Grid.Column="1" Background="{StaticResource AddressBrush}" CornerRadius="6"
                        Margin="8,0" Padding="12,0" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AddressBox" Grid.Column="0" Style="{StaticResource AddressBoxStyle}"
                                 PreviewKeyDown="Address_KeyDown"
                                 GotKeyboardFocus="Address_GotFocus" LostKeyboardFocus="Address_LostFocus"/>
                        <Button x:Name="ZoomPill" Grid.Column="1" Click="ZoomPill_Click" Visibility="Collapsed"
                                Foreground="{StaticResource TextDimBrush}" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" FontSize="12" Padding="6,2" ToolTip="Reset zoom (Ctrl+0)"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Native ad-block shield -->
                    <Button x:Name="ShieldBtn" Click="Shield_Click" Style="{StaticResource ToolButtonStyle}"
                            ToolTip="Ad &amp; tracker blocking" Padding="6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ShieldGlyph" Text="&#x1F6E1;" FontFamily="Segoe UI Emoji" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ShieldCount" Text="" FontSize="10.5" Margin="4,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </Button>
                    <!-- Extension icons (populated in code) -->
                    <ItemsControl x:Name="ExtIcons">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <Button x:Name="PuzzleBtn" Content="&#x1F9E9;" Click="Puzzle_Click"
                            FontFamily="Segoe UI Emoji" FontSize="14"
                            Style="{StaticResource ToolButtonStyle}" ToolTip="Extensions"/>
                    <Button x:Name="DownloadsBtn" Content="&#xE896;" Click="Downloads_Click"
                            Style="{StaticResource ToolButtonStyle}" ToolTip="Downloads" Visibility="Collapsed"/>
                    <Button x:Name="MenuBtn" Content="&#xE712;" Click="Menu_Click"
                            Style="{StaticResource ToolButtonStyle}" ToolTip="Menu"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bookmarks bar (toggle with Ctrl+Shift+B) -->
        <Border x:Name="BookmarksBar" Grid.Row="2" Background="{StaticResource ChromeBrush}" Padding="6,2"
                Visibility="Collapsed" BorderBrush="{StaticResource EdgeBorderBrush}" BorderThickness="0,1,0,0">
            <ItemsControl x:Name="BookmarksBarItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Border>

        <!-- Web content host + docked extension side panel -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid x:Name="ContentHost" Grid.Column="0" Background="{StaticResource WindowBrush}"/>
            <Border x:Name="SidePanel" Grid.Column="1" Width="400" Visibility="Collapsed"
                    Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource EdgeBorderBrush}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Height="34" Background="{StaticResource ChromeBrush}">
                        <TextBlock x:Name="SidePanelTitle" VerticalAlignment="Center" Margin="12,0"
                                   Foreground="{StaticResource TextBrush}" FontSize="12" FontWeight="SemiBold"/>
                        <Button Content="&#xE711;" Click="SidePanelClose_Click" HorizontalAlignment="Right"
                                Style="{StaticResource ToolButtonStyle}" ToolTip="Close panel"/>
                    </Grid>
                    <Grid x:Name="SidePanelHost"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Address bar autocomplete dropdown -->
        <Popup x:Name="SuggestPopup" PlacementTarget="{Binding ElementName=AddressHost}" Placement="Bottom"
               AllowsTransparency="True" StaysOpen="True" Focusable="False" HorizontalOffset="0" VerticalOffset="4">
            <Border Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource EdgeBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="5" MaxHeight="440"
                    Width="{Binding ActualWidth, ElementName=AddressHost}">
                <StackPanel x:Name="SuggestItems"/>
            </Border>
        </Popup>

        <!-- Downloads flyout -->
        <Popup x:Name="DownloadsPopup" PlacementTarget="{Binding ElementName=DownloadsBtn}" Placement="Bottom"
               HorizontalOffset="-260" AllowsTransparency="True" StaysOpen="False">
            <Border Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource EdgeBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="6" Width="320" MaxHeight="420">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Downloads" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource TextBrush}" Margin="8,4,8,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DownloadsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Margin="0,2" CornerRadius="6" Background="{StaticResource TabInactiveBrush}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FileName}" Foreground="{StaticResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis" FontSize="12"/>
                                            <ProgressBar Height="4" Margin="0,4" Minimum="0" Maximum="100"
                                                         Value="{Binding Progress, Mode=OneWay}" Foreground="{StaticResource AccentBrush}"
                                                         Background="{StaticResource AddressBrush}" BorderThickness="0"
                                                         Visibility="{Binding InProgress, Converter={StaticResource BoolToVis}}"/>
                                            <DockPanel>
                                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="Open" Tag="{Binding}" Click="Dl_Open" Style="{StaticResource MenuButtonStyle}"
                                                            Height="22" Padding="6,0" Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}"/>
                                                    <Button Content="Folder" Tag="{Binding}" Click="Dl_Folder" Style="{StaticResource MenuButtonStyle}"
                                                            Height="22" Padding="6,0" Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}"/>
                                                    <Button Content="Cancel" Tag="{Binding}" Click="Dl_Cancel" Style="{StaticResource MenuButtonStyle}"
                                                            Height="22" Padding="6,0" Visibility="{Binding InProgress, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Popup>

        <!-- Extensions manage flyout -->
        <Popup x:Name="ExtPopup" PlacementTarget="{Binding ElementName=PuzzleBtn}" Placement="Bottom"
               HorizontalOffset="-240" AllowsTransparency="True" StaysOpen="False">
            <Border Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource EdgeBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="6" Width="300" MaxHeight="440">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Extensions" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource TextBrush}" Margin="8,4,8,8"/>
                    <Button DockPanel.Dock="Bottom" Content="Load unpacked…" Click="ExtLoad_Click"
                            Style="{StaticResource MenuButtonStyle}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ExtManageList"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Popup>

        <!-- Extension popup flyout (renders an extension's popup.html) -->
        <Popup x:Name="ExtActionPopup" Placement="Bottom" AllowsTransparency="True" StaysOpen="False">
            <Border Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource EdgeBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="2">
                <Grid x:Name="ExtPopupHost" Width="360" Height="480"/>
            </Border>
        </Popup>

        <!-- Find-in-page bar (Popup renders above the WebView2 airspace) -->
        <Popup x:Name="FindPopup" AllowsTransparency="True" StaysOpen="False" Focusable="True">
            <Border Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource EdgeBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="6">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource AddressBrush}" CornerRadius="6" Padding="8,0" Width="220">
                        <TextBox x:Name="FindBox" Style="{StaticResource AddressBoxStyle}"
                                 KeyDown="FindBox_KeyDown" TextChanged="FindBox_TextChanged"/>
                    </Border>
                    <TextBlock x:Name="FindCount" Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="8,0" MinWidth="42"/>
                    <Button Content="&#xE70E;" Click="FindPrev_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Previous (Shift+Enter)"/>
                    <Button Content="&#xE70D;" Click="FindNext_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Next (Enter)"/>
                    <Button Content="&#xE711;" Click="FindClose_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Close (Esc)"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Ad-block shield panel -->
        <Popup x:Name="ShieldPopup" PlacementTarget="{Binding ElementName=ShieldBtn}" Placement="Bottom"
               AllowsTransparency="True" StaysOpen="False">
            <Border Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource EdgeBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="14" Width="288">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F6E1;" FontFamily="Segoe UI Emoji" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ShieldSite" Text="This site" Foreground="{StaticResource TextBrush}"
                                   FontSize="14" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                    </StackPanel>
                    <TextBlock x:Name="ShieldBlockedText" Text="" Foreground="{StaticResource TextDimBrush}"
                               FontSize="12.5" Margin="0,8,0,0"/>

                    <Border Height="1" Background="{StaticResource EdgeBorderBrush}" Margin="0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Shield for this site" Foreground="{StaticResource TextBrush}" FontSize="13.5"/>
                            <TextBlock x:Name="ShieldSiteSub" Text="Blocking ads &amp; trackers here" Foreground="{StaticResource TextDimBrush}" FontSize="11.5" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="ShieldSiteToggle" Grid.Column="1" VerticalAlignment="Center" Click="ShieldSiteToggle_Click"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource EdgeBorderBrush}" Margin="0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Block ads &amp; trackers (all sites)" Foreground="{StaticResource TextBrush}" FontSize="13.5" VerticalAlignment="Center"/>
                        <CheckBox x:Name="ShieldGlobalToggle" Grid.Column="1" VerticalAlignment="Center" Click="ShieldGlobalToggle_Click"/>
                    </Grid>

                    <Button Content="Settings…" Tag="settings" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Overflow menu -->
        <Popup x:Name="MenuPopup" PlacementTarget="{Binding ElementName=MenuBtn}" Placement="Bottom"
               HorizontalOffset="-224" AllowsTransparency="True" StaysOpen="False">
            <Border Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource EdgeBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="6" Width="280">
                <StackPanel>
                    <!-- Zoom + fullscreen control row (Chrome-style) -->
                    <Grid Margin="6,4,4,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Zoom" Margin="12,0,0,0" FontSize="14"
                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="&#xE738;" Click="MenuZoomOut_Click"
                                Style="{StaticResource ToolButtonStyle}" Width="30" Height="30" ToolTip="Zoom out (Ctrl -)"/>
                        <TextBlock Grid.Column="3" x:Name="MenuZoomPct" Text="100%" MinWidth="46" TextAlignment="Center"
                                   FontSize="13.5" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="4" Content="&#xE710;" Click="MenuZoomIn_Click"
                                Style="{StaticResource ToolButtonStyle}" Width="30" Height="30" ToolTip="Zoom in (Ctrl +)"/>
                        <Border Grid.Column="5" Width="1" Background="{StaticResource EdgeBorderBrush}" Margin="6,6"/>
                        <Button Grid.Column="6" Content="&#xE740;" Click="MenuFullscreen_Click"
                                Style="{StaticResource ToolButtonStyle}" Width="30" Height="30" ToolTip="Full screen (F11)"/>
                    </Grid>
                    <Border Height="1" Background="{StaticResource EdgeBorderBrush}" Margin="4,2,4,6"/>

                    <Button Content="New tab" Tag="newtab" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button x:Name="BookmarkThisBtn" Content="Bookmark this page" Tag="bookmark" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Bookmarks…" Tag="bookmarks" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="History…" Tag="history" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Find in page" Tag="find" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Print…" Tag="print" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Reader mode" Tag="reader" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Translate to English" Tag="translate" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Border Height="1" Background="{StaticResource EdgeBorderBrush}" Margin="4,6"/>
                    <Button Content="New private window" Tag="private" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button x:Name="ForceDarkBtn" Content="Force dark on all sites" Tag="forcedark" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button x:Name="SearchEngineBtn" Content="Search: Google" Tag="search" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Border Height="1" Background="{StaticResource EdgeBorderBrush}" Margin="4,6"/>
                    <Button Content="Sleep background tabs now" Tag="sleepnow" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Import from another browser…" Tag="import" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Set as default browser" Tag="default" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Check for updates" Tag="update" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Settings" Tag="settings" Click="Menu_Action" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Shared bookmarks/history list -->
        <Popup x:Name="ListPopup" PlacementTarget="{Binding ElementName=MenuBtn}" Placement="Bottom"
               HorizontalOffset="-284" AllowsTransparency="True" StaysOpen="False">
            <Border Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource EdgeBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="6" Width="320" MaxHeight="440">
                <DockPanel>
                    <TextBlock x:Name="ListTitle" DockPanel.Dock="Top" Foreground="{StaticResource TextBrush}"
                               FontWeight="Bold" FontSize="13" Margin="8,4,8,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ListItems"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Popup>

        <!-- Tab hover card (Chrome-style: title, domain, memory) -->
        <Popup x:Name="TabHoverPopup" Placement="Bottom" AllowsTransparency="True" StaysOpen="True"
               IsHitTestVisible="False" PopupAnimation="Fade" VerticalOffset="2">
            <Border Background="#F02A2A2E" BorderBrush="{StaticResource EdgeBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14,11" MaxWidth="320">
                <StackPanel>
                    <TextBlock x:Name="TabHoverTitle" Foreground="{StaticResource TextBrush}" FontSize="13"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TabHoverUrl" Foreground="{StaticResource TextDimBrush}" FontSize="12"
                               Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                    <Border Height="1" Background="{StaticResource EdgeBorderBrush}" Margin="0,9"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TabHoverMem" Foreground="{StaticResource TextDimBrush}" FontSize="12.5" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Update notification -->
        <Popup x:Name="UpdatePopup" PlacementTarget="{Binding ElementName=MenuBtn}" Placement="Bottom"
               HorizontalOffset="-236" AllowsTransparency="True" StaysOpen="False">
            <Border Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16" Width="292">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Update available" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="UpdateMsg" FontSize="12.5" Foreground="{StaticResource TextDimBrush}"
                               Margin="0,6,0,14" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Later" Click="UpdateLater_Click" Foreground="{StaticResource TextBrush}"
                                Background="#2A303E" BorderThickness="0" Padding="14,7" Cursor="Hand" Margin="0,0,8,0"/>
                        <Button x:Name="UpdateNowBtn" Content="Update now" Click="UpdateNow_Click" Foreground="White"
                                Background="{StaticResource AccentBrush}" BorderThickness="0" Padding="14,7" Cursor="Hand" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Transient toast -->
        <Popup x:Name="ToastPopup" AllowsTransparency="True" StaysOpen="True" IsHitTestVisible="False">
            <Border Background="#EE101014" BorderBrush="{StaticResource EdgeBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14,9">
                <TextBlock x:Name="ToastText" Foreground="White" FontSize="13"/>
            </Border>
        </Popup>
    </Grid>
</Window>
